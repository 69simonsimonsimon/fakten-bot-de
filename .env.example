# Claude / Anthropic API Key
# Erhältlich unter: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# TikTok Access Token
# Erhältlich nach OAuth-Flow im TikTok Developer Portal
# Benötigte Scopes: video.publish, video.upload
TIKTOK_ACCESS_TOKEN=act....

# Optional: TikTok Client Key (für OAuth-Refresh)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
